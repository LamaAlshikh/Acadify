@model Acadify.Models.CourseRecommendationViewModel
@{
    Layout = "_StudentLayout";
}

<link rel="stylesheet" href="~/css/CourseRecommendation.css" asp-append-version="true" />

<main class="cr-page">
    <section class="cr-shell">

        <h2 class="cr-title">course recommendation</h2>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="cr-message cr-error">
                @TempData["ErrorMessage"]
            </div>
        }

        @if (TempData["Success"] != null)
        {
            <div class="cr-message cr-success">
                @TempData["Success"]
            </div>
        }

        @if (TempData["InfoMessage"] != null)
        {
            <div class="cr-message cr-info">
                @TempData["InfoMessage"]
            </div>
        }

        <div class="cr-upload-wrap">
            <form asp-action="UploadTranscriptForRecommendation"
                  asp-controller="Student"
                  method="post"
                  enctype="multipart/form-data"
                  class="cr-upload-form">

                <input type="file"
                       id="transcriptFile"
                       name="transcriptFile"
                       accept=".pdf"
                       class="cr-file-input" />

                <label for="transcriptFile" class="cr-file-label">
                    Choose File
                </label>

                <button type="submit" class="cr-upload-btn">
                    Upload Transcript
                </button>
            </form>
        </div>

        @if (TempData["ParsedCoursesDebug"] != null)
        {
            <div class="cr-debug-box">
                @TempData["ParsedCoursesDebug"]
            </div>
        }

        <div class="cr-cards">
            @foreach (var course in Model.Cards.Take(4))
            {
                <div class="cr-card">
                    <div class="cr-card-top">
                        <span class="cr-code">@course.CourseId</span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(course.CourseName))
                    {
                        <div class="cr-course-name">@course.CourseName</div>
                    }

                    <div class="cr-course-hours">@course.Hours credit hour(s)</div>

                    <div class="cr-icons">
                        <form asp-action="SelectRecommendedCourse" asp-controller="Student" method="post">
                            <input type="hidden" name="courseId" value="@course.CourseId" />
                            <button type="submit" class="cr-icon cr-ok">✓</button>
                        </form>

                        <form asp-action="RemoveRecommendedCourse" asp-controller="Student" method="post">
                            <input type="hidden" name="courseId" value="@course.CourseId" />
                            <button type="submit" class="cr-icon cr-no">✕</button>
                        </form>

                        <form asp-action="SwapRecommendedCourse" asp-controller="Student" method="post">
                            <input type="hidden" name="courseId" value="@course.CourseId" />
                            <button type="submit" class="cr-icon cr-refresh">↻</button>
                        </form>
                    </div>
                </div>
            }

            @for (int i = Model.Cards.Count; i < 4; i++)
            {
                <div class="cr-card cr-card-empty">
                    <span class="cr-code">No course</span>
                </div>
            }
        </div>

        <div class="cr-manual-wrap">
            <h3 class="cr-manual-title">Free or Elective Courses</h3>

            <form asp-action="SaveManualElectiveCourses"
                  asp-controller="Student"
                  method="post"
                  class="cr-manual-form">

                <div class="cr-manual-grid">
                    <input asp-for="FreeElectiveCourse1"
                           class="cr-manual-input"
                           placeholder="Enter free course code" />

                    <input asp-for="FreeElectiveCourse2"
                           class="cr-manual-input"
                           placeholder="Enter elective course code" />

                    <input asp-for="FreeElectiveCourse3"
                           class="cr-manual-input"
                           placeholder="Enter elective course code" />
                </div>

                <button type="submit" class="cr-manual-btn">Save</button>
            </form>
        </div>

        <div class="cr-table-wrap">
            <table class="cr-table">
                <thead>
                    <tr>
                        <th colspan="2" class="cr-table-title">selected courses</th>
                    </tr>
                    <tr>
                        <th>course</th>
                        <th>credit</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Selected.Take(4))
                    {
                        <tr>
                            <td>@item.CourseId</td>
                            <td>@item.Hours</td>
                        </tr>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.FreeElectiveCourse1))
                    {
                        <tr>
                            <td>@Model.FreeElectiveCourse1</td>
                            <td>-</td>
                        </tr>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.FreeElectiveCourse2))
                    {
                        <tr>
                            <td>@Model.FreeElectiveCourse2</td>
                            <td>-</td>
                        </tr>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.FreeElectiveCourse3))
                    {
                        <tr>
                            <td>@Model.FreeElectiveCourse3</td>
                            <td>-</td>
                        </tr>
                    }

                    @{
                        var visibleRows =
                        Model.Selected.Take(4).Count() +
                        (!string.IsNullOrWhiteSpace(Model.FreeElectiveCourse1) ? 1 : 0) +
                        (!string.IsNullOrWhiteSpace(Model.FreeElectiveCourse2) ? 1 : 0) +
                        (!string.IsNullOrWhiteSpace(Model.FreeElectiveCourse3) ? 1 : 0);
                    }

                    

                    <tr class="cr-total-row">
                        <td>Total</td>
                        <td>@Model.Selected.Take(4).Sum(x => x.Hours)</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="cr-btn-wrap">
            <form asp-action="SendCourseRecommendationToAdvisor" asp-controller="Student" method="post">
                <button type="submit" class="cr-btn">Confirm &amp; send to advisor</button>
            </form>
        </div>

    </section>
</main>