    <script>
        function toggleNotifications() {
            const overlay = document.getElementById('notifOverlay');
            if (!overlay) return;
            overlay.classList.toggle('show');
        }

        function closeNotifications(e) {
            if (e) e.preventDefault();
            const overlay = document.getElementById('notifOverlay');
            if (!overlay) return;
            overlay.classList.remove('show');
        }
    </script>
