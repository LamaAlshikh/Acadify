@{
    Layout = "_AdvisorLayout";
}

<main class="advisor-form3-page">

    <!-- Top Header -->
    <section class="form3-top">
        <div class="form3-title">
            <div class="form3-icon">
                <i class="fa-solid fa-file-lines"></i>
            </div>
            <div>
                <h2>Meeting Record</h2>
                <p>(Form 3)</p>
            </div>
        </div>

        <button class="print-btn" onclick="window.print()">
            Print <i class="fa-solid fa-print"></i>
        </button>
    </section>

    <!-- Success message -->
    @if (TempData["Success"] != null)
    {
        <div class="form3-msg">@TempData["Success"]</div>
    }

    <section class="form3-card">

        <div class="form3-paper">

            <div class="form3-header">
                <div class="form3-title-center">
                    <h3>FORM-3 (Meeting Record)</h3>
                </div>
            </div>

            <div class="form3-student-line">
                <div>
                    <label>Student Name:</label>
                    <input type="text" name="StudentName" class="line-input" />
                </div>

                <div>
                    <label>Student ID:</label>
                    <input type="text" name="StudentId" class="line-input" />
                </div>
            </div>

            <table class="form3-table">
                <thead>
                    <tr>
                        <th>Meeting #</th>
                        <th>Meeting date</th>
                        <th>Meeting Purpose</th>
                        <th>Referring Student to someone else</th>
                        <th>Proposed Solutions / Advise / Brief notes</th>
                    </tr>
                </thead>

                <tbody>
                    @for (int i = 1; i <= 3; i++)
                    {
                        <tr>
                            <td class="center">@i</td>

                            <td>
                                <input type="text" name="Rows[@i].MeetingDate" class="cell-input" placeholder="Year / Fall / Spring / Summer" />
                            </td>

                            <td>
                                <label class="check-row"><input type="checkbox" /> Academic</label>
                                <label class="check-row"><input type="checkbox" /> Career</label>
                                <label class="check-row"><input type="checkbox" /> Other</label>
                            </td>

                            <td>
                                <div class="mini-field">
                                    <span>Name:</span>
                                    <input type="text" class="cell-input" />
                                </div>
                                <div class="mini-field">
                                    <span>Reason:</span>
                                    <input type="text" class="cell-input" />
                                </div>
                            </td>

                            <td>
                                <textarea class="cell-textarea" rows="4"></textarea>
                                <div class="initials">
                                    <span>(Student Initial)</span>
                                    <span>(Advisor Initial)</span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </section>

    <!-- Bottom Actions -->
    <section class="form3-actions">

        <form method="post" asp-action="SendForm3" asp-controller="Advisor">
            <button type="submit" class="btn-primary-wide">
                Send To The Advising Committee
            </button>
        </form>

        <form method="post" asp-action="AddNotesForm3" asp-controller="Advisor" class="notes-form">
            <input type="text" name="notes" placeholder="Add Notes..." class="notes-input" />
            <button type="submit" class="btn-secondary">
                Add Notes +
            </button>
        </form>

        <a asp-action="Form3History" asp-controller="Advisor" class="btn-light">
            Form History
        </a>

    </section>

</main>