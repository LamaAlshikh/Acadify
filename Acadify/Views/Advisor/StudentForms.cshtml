@model List<Acadify.Models.StudentFormsVM>

@{
    Layout = "_AdvisorLayout";
    ViewData["Title"] = "Student Forms";
}

@if (TempData["SuccessMessage"] != null)
{
    <div id="successToast" class="success-toast">
        <span>@TempData["SuccessMessage"]</span>
    </div>
}

<div class="studentforms-page">
    <div class="app">
        <main class="main">

            <div class="topbar">
                <div class="user-line">
                    <div class="mini logo">
                        <img src="~/images/user.png" alt="Logo" />
                    </div>
                    <h2>Lama alshikh</h2>
                </div>
            </div>

            <section class="panel">

                <!-- الصف الأول -->
                <div class="grid">

                    @foreach (var form in Model.Take(3))
                    {
                        <div class="student-form-card">

                            <div class="icon-wrap">
                                <div class="icon-inner">
                                    <i class="fa-regular fa-file-lines"></i>
                                </div>
                            </div>

                            <h3>@form.FormTitle</h3>

                            <div class="form-id">(Form @form.FormId)</div>

                            <div class="actions">

                                <a asp-controller="Advisor"
                                   asp-action="ViewForm"
                                   asp-route-formId="@form.FormId"
                                   class="action-btn">
                                    <i class="fa-regular fa-eye"></i>
                                    <span>View</span>
                                </a>

                                <a asp-controller="Advisor"
                                   asp-action="PrintForm"
                                   asp-route-formId="@form.FormId"
                                   class="action-btn">
                                    <i class="fa-solid fa-print"></i>
                                    <span>Print</span>
                                </a>

                                <form asp-controller="Advisor"
                                      asp-action="SendForm"
                                      method="post">

                                    <input type="hidden"
                                           name="formId"
                                           value="@form.FormId" />

                                    <button type="submit"
                                            class="action-btn">
                                        <i class="fa-regular fa-paper-plane"></i>
                                        <span>Send</span>
                                    </button>

                                </form>

                            </div>
                        </div>
                    }

                </div>


                <!-- الصف الثاني -->
                <div class="grid bottom">

                    @foreach (var form in Model.Skip(3))
                    {
                        <div class="student-form-card">

                            <div class="icon-wrap">
                                <div class="icon-inner">
                                    <i class="fa-regular fa-file-lines"></i>
                                </div>
                            </div>

                            <h3>@form.FormTitle</h3>

                            <div class="form-id">(Form @form.FormId)</div>

                            <div class="actions">

                                <a asp-controller="Advisor"
                                   asp-action="ViewForm"
                                   asp-route-formId="@form.FormId"
                                   class="action-btn">
                                    <i class="fa-regular fa-eye"></i>
                                    <span>View</span>
                                </a>

                                <a asp-controller="Advisor"
                                   asp-action="PrintForm"
                                   asp-route-formId="@form.FormId"
                                   class="action-btn">
                                    <i class="fa-solid fa-print"></i>
                                    <span>Print</span>
                                </a>

                                <form asp-controller="Advisor"
                                      asp-action="SendForm"
                                      method="post">

                                    <input type="hidden"
                                           name="formId"
                                           value="@form.FormId" />

                                    <button type="submit"
                                            class="action-btn">
                                        <i class="fa-regular fa-paper-plane"></i>
                                        <span>Send</span>
                                    </button>

                                </form>

                            </div>

                        </div>
                    }

                </div>

            </section>

        </main>
    </div>
</div>

<script>
    setTimeout(function () {
        var toast = document.getElementById("successToast");
        if (toast) {
            toast.remove();
        }
    }, 3000);
</script>