    <script>
            const emailInput = document.getElementById("emailInput");
            const roleContainer = document.getElementById("roleContainer");
            const studentIdContainer = document.getElementById("studentIdContainer");
            const roleSelect = document.getElementById("roleSelect");

            function toggleFields() {
                const email = (emailInput.value || "").toLowerCase().trim();

                if (email.endsWith("@@kau.edu.sa") && !email.endsWith("@@stu.kau.edu.sa")) {
                    roleContainer.style.display = "block";
                    studentIdContainer.style.display = "none";
                } else if (email.endsWith("@@stu.kau.edu.sa")) {
                    roleContainer.style.display = "none";
                    studentIdContainer.style.display = "block";
                    roleSelect.value = "";
                } else {
                    roleContainer.style.display = "none";
                    studentIdContainer.style.display = "block";
                    roleSelect.value = "";
                }
            }

            emailInput.addEventListener("input", toggleFields);
            window.addEventListener("load", toggleFields);
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
