@model Acadify.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/css/login.css" />
</head>
<body>
    <div class="login-page">
        <div class="left-bar"></div>

        <div class="main">
            <div class="card">

                <div class="logo">
                    <img src="~/images/newLogo.png" alt="Acadify Logo" class="logo-img" />
                </div>

                <div class="title">login to <span>your account</span></div>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div style="color:green; margin-bottom:10px; text-align:center;">
                        @TempData["SuccessMessage"]
                    </div>
                }

                <form class="form" asp-action="Login" asp-controller="Account" method="post">
                    @Html.AntiForgeryToken()

                    <input class="input" asp-for="Email" type="email" placeholder="Email" id="loginEmailInput" />
                    <span asp-validation-for="Email" class="text-danger"></span>

                    <div id="loginRoleContainer">
                        <select class="input" asp-for="Role" id="loginRoleSelect">
                            <option value="">Choose role</option>
                            <option value="Admin">Admin</option>
                            <option value="Advisor">Advisor</option>
                        </select>
                        <span asp-validation-for="Role" class="text-danger"></span>
                    </div>

                    <input class="input" asp-for="Password" type="password" placeholder="Password" />
                    <span asp-validation-for="Password" class="text-danger"></span>

                    <div asp-validation-summary="All" class="text-danger"></div>

                    <button class="btn" type="submit">Login</button>

                    <div class="section">
                        Do not have account?
                        <div>
                            <a class="btn btn-secondary"
                               style="display:inline-block;text-decoration:none;line-height:22px;"
                               href="/Account/SignUp">Sign up</a>
                        </div>
                    </div>
                </form>

            </div>
        </div>
    </div>
    <script>
            const loginEmailInput = document.getElementById("loginEmailInput");
            const loginRoleSelect = document.getElementById("loginRoleSelect");

            function handleRoleRequirement() {
                const email = (loginEmailInput.value || "").toLowerCase().trim();
                const isStudentEmail = email.endsWith("@@stu.kau.edu.sa");

                if (isStudentEmail) {
                    loginRoleSelect.value = "";
                    loginRoleSelect.disabled = true;
                } else {
                    loginRoleSelect.disabled = false;
                }
            }

            loginEmailInput.addEventListener("input", handleRoleRequirement);
            window.addEventListener("load", handleRoleRequirement);
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
</body>
</html>